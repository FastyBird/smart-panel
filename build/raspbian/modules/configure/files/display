# Smart Panel Display Configuration
#
# Override the physical display dimensions (width_mm,height_mm) to control
# the UI scaling. Smaller values = larger UI elements.
#
# Examples:
#   reTerminal 5" (default auto-detect ~108x65mm, override for larger UI):
#     FB_DISPLAY_DIMENSIONS=90,54
#   7" RPi touchscreen:
#     FB_DISPLAY_DIMENSIONS=155,86
#   Leave empty for auto-detection:
#     FB_DISPLAY_DIMENSIONS=
FB_DISPLAY_DIMENSIONS=

# Rotate the display output. Valid values: 0, 90, 180, 270
#
# Examples:
#   Upside-down mount:
#     FB_DISPLAY_ROTATION=180
#   Portrait (rotated left):
#     FB_DISPLAY_ROTATION=90
#   Leave empty for default (no rotation):
#     FB_DISPLAY_ROTATION=
FB_DISPLAY_ROTATION=

# Enable accelerometer-based auto-rotation (reTerminal CM4 only).
# When enabled, the smart-panel-auto-rotate service monitors the
# built-in accelerometer and restarts the display with the correct
# rotation when the device orientation changes.
#
# Valid values: 0 (disabled, default), 1 (enabled)
#
# Note: When auto-rotate is active, FB_DISPLAY_ROTATION is updated
# automatically and any manual value will be overwritten on rotation.
#
# Tunables (optional):
#   FB_AUTO_ROTATE_POLL_INTERVAL=1    # Polling interval in seconds
#   FB_AUTO_ROTATE_DEBOUNCE=3         # Consecutive readings before rotating
#   FB_AUTO_ROTATE_THRESHOLD=400      # Minimum tilt in mg to detect orientation
FB_AUTO_ROTATE=0
