[Unit]
Description=Smart Panel First Boot Setup
After=network-online.target
Wants=network-online.target
ConditionPathExists=/var/lib/smart-panel/.first-boot
Before=smart-panel.service

[Service]
Type=oneshot
ExecStart=/usr/lib/smart-panel/first-boot.sh
RemainAfterExit=true
StandardOutput=journal
StandardError=journal
SyslogIdentifier=smart-panel-firstboot

[Install]
WantedBy=multi-user.target
