{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"testEnvironment": "node",
	"testRegex": "\\.e2e-spec\\.ts$",
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"moduleNameMapper": {
		"^inquirer$": "<rootDir>/__mocks__/inquirer.ts"
	},
	"setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"]
}
