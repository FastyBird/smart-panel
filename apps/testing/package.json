{
  "name": "@fastybird/smart-panel-testing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start:dev": "vite",
    "start:preview": "vite preview",
    "build": "tsc -b && vite build",
    "type-check": "tsc --noEmit",
    "lint:js": "eslint src/",
    "lint:js:fix": "eslint src/ --fix",
    "pretty": "pnpm pretty:write && pnpm pretty:check",
    "pretty:write": "prettier --write src/",
    "pretty:check": "prettier --check src/"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "postcss": "^8.5.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.0"
  },
  "engines": {
    "node": ">=24"
  }
}
