{
  "name": "@fastybird/smart-panel-admin",
  "version": "0.5.0-alpha.2",
  "type": "module",
  "description": "Powerful application for administrating and integrating the FastyBird IoT Smart Panel",
  "keywords": [
    "fastybird",
    "iot",
    "smart-panel",
    "admin",
    "administration",
    "iot-platform",
    "device-management",
    "home-automation",
    "api",
    "websockets",
    "iot-backend",
    "automation",
    "smart-home",
    "fastybird-platform",
    "smart-devices",
    "connected-devices",
    "integration"
  ],
  "homepage": "https://smart-panel.fastybird.com",
  "bugs": "https://github.com/FastyBird/smart-panel/issues",
  "license": "Apache-2.0",
  "author": {
    "name": "Studio81 Labs s.r.o.",
    "email": "dev@studio81.cz",
    "url": "https://www.studio81.cz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FastyBird/smart-panel.git"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "run-p type-check \"build:no-check {@}\" --",
    "build:no-check": "vite build",
    "start:dev": "vite",
    "start:preview": "vite preview",
    "start:prod": "serve -s ./dist",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:styles": "stylelint 'src/**/*.scss'",
    "lint:deps": "npx madge --circular src --extensions ts,tsx --ts-config tsconfig.json",
    "pretty": "pnpm pretty:write && pnpm pretty:check",
    "pretty:check": "prettier \"src/**/*.{ts,scss,vue}\" --check",
    "pretty:write": "prettier \"src/**/*.{ts,scss,vue}\" --write",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest --watch",
    "test:cov": "vitest --run --coverage",
    "test:cov:watch": "vitest --watch --coverage",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --build",
    "generate:openapi": "openapi-typescript ../../spec/api/v1/openapi.json -o ./src/openapi.ts --enum --dedupe-enums --root-types --default-non-nullable=false",
    "generate:spec": "node ./tools/build_devices_spec.mjs && node ./tools/build_channel_spec.mjs && node ./tools/build_weather_cities.mjs"
  },
  "dependencies": {
    "@iconify/json": "^2.2.449",
    "@iconify/vue": "^5",
    "@sentry/vue": "^10.43.0",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "@vueuse/core": "^14.0.0",
    "async-validator": "^4.2.5",
    "consola": "^3.4.2",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "element-plus": "^2.13.5",
    "gridstack": "^12.4.2",
    "i18n-iso-countries": "^7.14.0",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.23",
    "marked": "^17.0.4",
    "md5": "^2.3.0",
    "mitt": "^3.0.1",
    "natural-orderby": "^5.0.0",
    "nprogress": "^0.2.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript-helpers": "^0.1.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "serve": "^14.2.6",
    "socket.io-client": "^4.8.3",
    "unocss": "^66.6.6",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-meta": "3.0.0-alpha.10",
    "vue-router": "^5",
    "vue3-cookies": "^1.0.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.0",
    "@playwright/test": "^1.58.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28",
    "@types/lodash": "^4.17.24",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.12.0",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "^1.5.6",
    "@unocss/transformer-variant-group": "^66.6.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9",
    "eslint": "^10",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-vue": "^10",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "start-server-and-test": "^2.1.5",
    "stylelint": "^17",
    "stylelint-config-recommended-scss": "^17",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40",
    "stylelint-config-standard-scss": "^17",
    "stylelint-order": "^8.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vite-plugin-vconsole": "^2.1.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.0.0",
    "yaml": "^2.7.1"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}